# MemoClaw — Self-hosted memory engine
# Copy to .env and fill in your values

# === API ===
MEMOCLAW_API_KEY=mc-changeme
PORT=8420

# === LLM Provider ===
# Providers: openrouter, openai, ollama, custom
LLM_PROVIDER=openrouter
LLM_API_KEY=sk-or-v1-your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# For Ollama:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=llama3.1
# LLM_API_KEY=ollama

# For OpenAI direct:
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# === Embedding Provider ===
# Providers: openai, ollama, custom
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-openai-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# For Ollama embeddings:
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_BASE_URL=http://ollama:11434/v1
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_API_KEY=ollama

# === Database (set by docker compose, override if external) ===
DATABASE_URL=postgresql+asyncpg://memoclaw:memoclaw@postgres:5432/memoclaw

# === Workers ===
# Max concurrent document processing tasks
WORKER_CONCURRENCY=4
# Memory decay check interval (seconds)
DECAY_CHECK_INTERVAL=3600

# === Logging ===
LOG_LEVEL=info
